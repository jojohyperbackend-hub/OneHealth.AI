# URL webapp Next.js yang punya endpoint POST /api/webhook/whatsapp
# Contoh: https://one-health-ai-pearl.vercel.app  (JANGAN pakai trailing slash)
ONEHEALTH_BACKEND_URL=

# Sama persis dengan HERMES_WEBHOOK_SECRET di env Vercel — dikirim sebagai
# header x-hermes-secret ke /api/webhook/whatsapp.
HERMES_WEBHOOK_SECRET=
